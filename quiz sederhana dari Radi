<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kuis 30 Soal Umum</title>
    <style>
        body { font-family: sans-serif; display: flex; justify-content: center; padding: 20px; background-color: #f0f2f5; }
        #quiz-box { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); width: 100%; max-width: 600px; }
        .option-btn { display: block; width: 100%; padding: 12px; margin: 8px 0; cursor: pointer; border: 1px solid #ddd; border-radius: 8px; background: #fff; transition: 0.3s; }
        .option-btn:hover { background: #007bff; color: white; border-color: #007bff; }
        #progress { font-size: 0.9em; color: #666; margin-bottom: 10px; }
    </style>
</head>
<body>

<div id="quiz-box">
    <div id="progress">Soal 1 dari 30</div>
    <h2 id="question">Memuat soal...</h2>
    <div id="options-container"></div>
</div>

<script>
    const quizData = [
        { q: "Apa ibu kota Indonesia?", a: ["Jakarta", "Nusantara", "Bandung"], correct: 1 },
        { q: "Planet terbesar di tata surya?", a: ["Bumi", "Mars", "Jupiter"], correct: 2 },
        { q: "Siapa penemu lampu pijar?", a: ["Nikola Tesla", "Thomas Edison", "Albert Einstein"], correct: 1 },
        { q: "Apa bahasa resmi negara Brazil?", a: ["Spanyol", "Portugis", "Inggris"], correct: 1 },
        { q: "Gunung tertinggi di dunia?", a: ["K2", "Everest", "Fuji"], correct: 1 },
        { q: "Hewan tercepat di darat?", a: ["Singa", "Kuda", "Cheetah"], correct: 2 },
        { q: "Berapa jumlah provinsi di Indonesia saat ini?", a: ["34", "38", "37"], correct: 1 },
        { q: "Apa nama zat hijau pada daun?", a: ["Klorofil", "Karoten", "Hemoglobin"], correct: 0 },
        { q: "Samudra terluas di dunia?", a: ["Atlantik", "Hindia", "Pasifik"], correct: 2 },
        { q: "Siapa pencipta lagu kebangsaan Indonesia Raya?", a: ["W.R. Supratman", "Kusbini", "Ismail Marzuki"], correct: 0 },
        { q: "Apa mata uang Jepang?", a: ["Yuan", "Yen", "Won"], correct: 1 },
        { q: "Negara dengan penduduk terbanyak di dunia (2025/2026)?", a: ["Tiongkok", "India", "Amerika Serikat"], correct: 1 },
        { q: "Planet yang dijuluki planet merah?", a: ["Venus", "Mars", "Saturnus"], correct: 1 },
        { q: "Berapa jumlah pemain dalam satu tim sepak bola?", a: ["10", "11", "12"], correct: 1 },
        { q: "Apa unsur kimia untuk emas?", a: ["Fe", "Ag", "Au"], correct: 2 },
        { q: "Siapa penulis novel Laskar Pelangi?", a: ["Andrea Hirata", "Tere Liye", "Dee Lestari"], correct: 0 },
        { q: "Organ tubuh yang memompa darah?", a: ["Paru-paru", "Jantung", "Hati"], correct: 1 },
        { q: "Negara dengan julukan Negeri Matahari Terbit?", a: ["Korea Selatan", "Jepang", "Tiongkok"], correct: 1 },
        { q: "Apa ibu kota Australia?", a: ["Sydney", "Melbourne", "Canberra"], correct: 2 },
        { q: "Berapa titik didih air?", a: ["80°C", "90°C", "100°C"], correct: 2 },
        { q: "Apa simbol kimia untuk air?", a: ["O2", "H2O", "CO2"], correct: 1 },
        { q: "Pulau terbesar di Indonesia?", a: ["Jawa", "Kalimantan", "Sumatera"], correct: 1 },
        { q: "Siapa presiden pertama Indonesia?", a: ["Soeharto", "Soekarno", "Habibie"], correct: 1 },
        { q: "Apa warna bendera negara Belanda?", a: ["Merah-Putih-Biru", "Merah-Putih-Hijau", "Merah-Kuning-Biru"], correct: 0 },
        { q: "Hewan mamalia terbesar di dunia?", a: ["Gajah", "Paus Biru", "Jerapah"], correct: 1 },
        { q: "Apa nama ibu kota Prancis?", a: ["Berlin", "Madrid", "Paris"], correct: 2 },
        { q: "Berapa jumlah sisi sebuah segitiga?", a: ["2", "3", "4"], correct: 1 },
        { q: "Apa nama mata uang yang digunakan di Eropa?", a: ["Dollar", "Euro", "Pound"], correct: 1 },
        { q: "Satu tahun kabisat terdiri dari berapa hari?", a: ["365", "366", "367"], correct: 1 },
        { q: "Apa nama alat untuk mengukur suhu?", a: ["Barometer", "Termometer", "Hidrometer"], correct: 1 }
    ];

    let currentIdx = 0, score = 0;

    function loadQuestion() {
        const data = quizData[currentIdx];
        document.getElementById('progress').innerText = `Soal ${currentIdx + 1} dari ${quizData.length}`;
        document.getElementById('question').innerText = data.q;
        const container = document.getElementById('options-container');
        container.innerHTML = '';
        data.a.forEach((opt, i) => {
            const btn = document.createElement('button');
            btn.innerText = opt;
            btn.className = 'option-btn';
            btn.onclick = () => checkAnswer(i);
            container.appendChild(btn);
        });
    }

    function checkAnswer(idx) {
        if (idx === quizData[currentIdx].correct) score++;
        currentIdx++;
        if (currentIdx < quizData.length) {
            loadQuestion();
        } else {
            document.getElementById('quiz-box').innerHTML = `<h2>Kuis Selesai!</h2><p>Skor total kamu: <strong>${score} / ${quizData.length}</strong></p><button class="option-btn" onclick="location.reload()">Mulai Lagi</button>`;
        }
    }

    loadQuestion();
</script>
</body>
</html>
